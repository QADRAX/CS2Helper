{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch client-ui (Vite)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:client-ui"],
      "console": "integratedTerminal"
    },
    {
      "name": "Launch server-ui (Vite)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:server-ui"],
      "console": "integratedTerminal"
    }
  ]
}