{
  "name": "cs2helper",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Qadrax",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run typecheck && npm run build --workspaces",
    "lint": "eslint packages/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:gsi-processor": "npm run build --workspace=@cs2helper/gsi-processor",
    "lint:gsi-processor": "npm run lint --workspace=@cs2helper/gsi-processor",
    "test:gsi-processor": "npm run test --workspace=@cs2helper/gsi-processor",
    "build:gsi-gateway": "npm run build --workspace=@cs2helper/gsi-gateway",
    "lint:gsi-gateway": "npm run lint --workspace=@cs2helper/gsi-gateway",
    "test:gsi-gateway": "npm run test --workspace=@cs2helper/gsi-gateway",
    "build:shared": "npm run build --workspace=@cs2helper/shared",
    "lint:shared": "npm run lint --workspace=@cs2helper/shared",
    "build:cli-common": "npm run build --workspace=@cs2helper/cli-common",
    "lint:cli-common": "npm run lint --workspace=@cs2helper/cli-common",
    "test:cli-common": "npm run test --workspace=@cs2helper/cli-common",
    "build:gsi-processor-ink": "npm run build --workspace=@cs2helper/gsi-processor-ink",
    "lint:gsi-processor-ink": "npm run lint --workspace=@cs2helper/gsi-processor-ink",
    "build:gsi-bench-cli": "npm run build --workspace=@cs2helper/gsi-bench-cli",
    "lint:gsi-bench-cli": "npm run lint --workspace=@cs2helper/gsi-bench-cli",
    "test:gsi-bench-cli": "npm run test --workspace=@cs2helper/gsi-bench-cli"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
