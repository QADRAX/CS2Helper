{
  "name": "cs2helper",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Qadrax",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": "0.25.12",
      "postcss@<8.5.10": "^8.5.14"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "@tree-sitter-grammars/tree-sitter-yaml",
      "core-js-pure",
      "tree-sitter",
      "tree-sitter-json"
    ]
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:build": "turbo run build",
    "turbo:lint": "turbo run lint",
    "turbo:test": "turbo run test",
    "dev:gsi-cli": "pnpm --filter @cs2helper/gsi-cli dev",
    "dev:gsi-bench-cli": "pnpm --filter @cs2helper/gsi-bench-cli dev",
    "build:gsi-processor": "pnpm --filter @cs2helper/gsi-processor build",
    "lint:gsi-processor": "pnpm --filter @cs2helper/gsi-processor lint",
    "test:gsi-processor": "pnpm --filter @cs2helper/gsi-processor test",
    "build:gsi-gateway": "pnpm --filter @cs2helper/gsi-gateway build",
    "lint:gsi-gateway": "pnpm --filter @cs2helper/gsi-gateway lint",
    "test:gsi-gateway": "pnpm --filter @cs2helper/gsi-gateway test",
    "build:shared": "pnpm --filter @cs2helper/shared build",
    "lint:shared": "pnpm --filter @cs2helper/shared lint",
    "build:cli-common": "pnpm --filter @cs2helper/cli-common build",
    "lint:cli-common": "pnpm --filter @cs2helper/cli-common lint",
    "test:cli-common": "pnpm --filter @cs2helper/cli-common test",
    "build:cs2-client-listener-ink": "pnpm --filter @cs2helper/cs2-client-listener-ink build",
    "lint:cs2-client-listener-ink": "pnpm --filter @cs2helper/cs2-client-listener-ink lint",
    "build:gsi-bench-cli": "pnpm --filter @cs2helper/gsi-bench-cli build",
    "lint:gsi-bench-cli": "pnpm --filter @cs2helper/gsi-bench-cli lint",
    "test:gsi-bench-cli": "pnpm --filter @cs2helper/gsi-bench-cli test",
    "build:auth": "pnpm --filter @cs2helper/auth build",
    "lint:auth": "pnpm --filter @cs2helper/auth lint",
    "test:auth": "pnpm --filter @cs2helper/auth test",
    "dev:community-web": "pnpm --filter @cs2helper/community-web dev",
    "build:community-web": "pnpm --filter @cs2helper/shared build && pnpm --filter @cs2helper/auth build && pnpm --filter @cs2helper/community-web build",
    "lint:community-web": "pnpm --filter @cs2helper/community-web lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
