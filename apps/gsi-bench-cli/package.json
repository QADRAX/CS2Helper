{
  "name": "@cs2helper/gsi-bench-cli",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "dev": "vite-node src/index.ts"
  },
  "dependencies": {
    "@cs2helper/cli-common": "workspace:*",
    "@cs2helper/cs2-client-listener": "workspace:*",
    "@cs2helper/cs2-client-listener-ink": "workspace:*",
    "@cs2helper/gsi-processor": "workspace:*",
    "@cs2helper/shared": "workspace:*",
    "@cs2helper/tick-hub": "workspace:*",
    "ink": "^4.4.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.0",
    "vite": "^8.0.10",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
