# Copia este fichero a `.env.local` (recomendado con Next.js) o `.env` en la raíz de `apps/community-web`.
# Next carga `.env.local` automáticamente; el script `pnpm db:migrate` usa `dotenv` y lee `.env` por defecto.

# --- Base de datos ---
# `postgres` (por defecto): servidor PostgreSQL real → necesitas DATABASE_URL.
# `pglite` o `file`: Postgres en WASM con datos en disco (sin Docker ni servidor PG). Solo para desarrollo local.
CS2H_DATABASE_DRIVER=pglite

# Ruta del directorio de datos PGlite (relativa al cwd al ejecutar `pnpm dev` / `pnpm db:migrate`, normalmente esta carpeta `apps/community-web`).
CS2H_PGLITE_DATA_DIR=.data/pglite

# Obligatorio si CS2H_DATABASE_DRIVER=postgres (o sin definir driver).
# DATABASE_URL=postgresql://usuario:clave@127.0.0.1:5432/cs2helper

# --- Auth / JWT ---
JWT_SECRET=cambia-esto-en-desarrollo-minimo-32-caracteres-recomendado

# --- App ---
# URL pública (OpenID return_to / realm, cookies, redirects). En local suele ser:
APP_URL=http://localhost:3000

# Opcional
# JWT_ISSUER=cs2helper-community
# JWT_AUDIENCE=community-web
# NEXT_PUBLIC_SITE_NAME=CS2 Community

# Confiar en X-Forwarded-For si hay proxy (nginx, etc.)
# TRUST_PROXY=true

# --- Primer administrador (Steam OpenID) ---
# SteamID64 del admin inicial cuando la BD aún no tiene ningún usuario con rol `admin`.
# Tras existir un admin, se ignora; nuevos usuarios solo entran con invitación.
# CS2H_BOOTSTRAP_ROOT_STEAM_ID=76561198000000000

# --- Registro ---
# CS2H_DEFAULT_REGISTRATION_ROLE=member

# --- TTL tokens (segundos) ---
# CS2H_ACCESS_TOKEN_TTL_SEC=900
# CS2H_REFRESH_TOKEN_TTL_SEC=1209600

# --- Rate limits (por minuto e IP) ---
# CS2H_RATE_LIMIT_LOGIN_PER_MIN=30
# CS2H_RATE_LIMIT_ADMIN_PER_MIN=120
