# Copy to `.env` (gitignored):  cp .env.example .env
#
# --- Status HTTP (default ON in image; see CS2_STATUS_SERVER) ---
# Optional Basic auth: set BOTH variables, or leave both unset for open endpoints (only if 28080 is not reachable from untrusted networks).
# Save .env with LF line endings (CRLF on Windows can append \r to values and break Basic auth).
# Verify in container: docker compose exec cs2-dedicated-server sh -c 'echo -n "$CS2_STATUS_HTTP_USER" | wc -c'
# Optional: CS2_STATUS_HTTP_DEBUG=1 logs whether auth is on and credential lengths (no values).
# CS2_STATUS_HTTP_USER=myuser
# CS2_STATUS_HTTP_PASSWORD=mysecret
# Optional: SSE cadence for GET /events (ms, min 200). Default 1000.
# CS2_STATUS_SSE_INTERVAL_MS=1000
# Optional: send every tick even if JSON unchanged (0|false|no). Default 1 (coalesce duplicate frames).
# CS2_STATUS_SSE_COALESCE=1
#
# --- Game server login token (GSLT): public listing / Internet without LAN-only ---
# Create at https://steamcommunity.com/dev/managegameservers (App ID 730). Passed as +sv_setsteamaccount.
SRCDS_TOKEN=
#
# --- Server browser name (+hostname) ---
CS2_HOSTNAME=CS2Helper
#
# --- RCON (-usercon is always on): same port as CS2_PORT unless you proxy elsewhere ---
# Strong secret recommended. Alias: CS2_RCONPW (same meaning).
CS2_RCON_PASSWORD=
#
# --- GSI endpoint the server POSTs to ---
GSI_URI=http://host.docker.internal:3000
#
# --- Optional: host port mapping (used by docker-compose.yml only) ---
# HOST_PORT_CS2=27015
# HOST_PORT_CS2_TV=27020
# HOST_PORT_CS2_STATUS=28080
#
# --- Optional: game / Workshop (passed through to the container) ---
# CS2_START_MAP=de_dust2
# CS2_PORT=27015
# CS2_TV_PORT=27020
# CS2_MAX_PLAYERS=10
# CS2_RCON_PASSWORD=
# CS2_HOST_WORKSHOP_MAP=
# CS2_HOST_WORKSHOP_COLLECTION=
# CS2_STEAM_AUTH_KEY=
# CS2_STATUS_SERVER=1
# CS2_STATUS_PORT=28080
#
# SteamCMD on each start: 1 = app_update 730 validate (slow ~66GB checksum); 0 = app_update only (faster).
# CS2_STEAMCMD_VALIDATE=0
