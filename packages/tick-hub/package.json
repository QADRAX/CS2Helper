{
  "name": "@cs2helper/tick-hub",
  "version": "1.0.0",
  "description": "Master-clock-aligned multi-source capture and tick recording (polling or push/webhook masters).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cs2helper/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
