{
  "name": "@cs2helper/cs2-dedicated-status-http",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal HTTP sidecar for CS2 dedicated Docker: health/ready + spawn server binary.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "start": "node dist/infrastructure/main.js"
  },
  "dependencies": {
    "@cs2helper/shared": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "eslint": "^10.3.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
