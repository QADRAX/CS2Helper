{
  "name": "@cs2helper/auth",
  "version": "1.0.0",
  "description": "Authentication and RBAC core (PostgreSQL, JWT, roles, permissions, profiles).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "drizzle"],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@cs2helper/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.0.10",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.13",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.1.3"
  }
}
