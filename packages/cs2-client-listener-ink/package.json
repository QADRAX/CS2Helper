{
  "name": "@cs2helper/cs2-client-listener-ink",
  "version": "1.0.0",
  "description": "Ink dashboard for CS2 client listener tick streams (GSI + aligned telemetry).",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm run clean && vite build && tsc --emitDeclarationOnly",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
