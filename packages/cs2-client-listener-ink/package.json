  },
  "dependencies": {
    "@cs2helper/cs2-client-listener": "workspace:*",
    "@cs2helper/gsi-processor": "workspace:*",
    "@cs2helper/tick-hub": "workspace:*"
  },
  "peerDependencies": {
    "ink": "^4.4.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "ink": "^4.4.1",
    "vite": "^8.0.10"
  }
}
